# Server Environment Variables
# Use ANY ONE of these API keys - the system auto-detects the LLM provider

PORT=5000

# OpenAI (GPT-4o-mini recommended)
# OPENAI_API_KEY=sk-...

# Google Gemini (Gemini 2.0 Flash recommended)
# GEMINI_API_KEY=AI...

# Anthropic Claude (Claude 3.5 Sonnet recommended)
# ANTHROPIC_API_KEY=sk-ant-...
